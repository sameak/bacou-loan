{
  "expo": {
    "name": "Bacou",
    "slug": "bacou-loan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bacou",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bacou.loan",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Bacou needs access to your photo library to attach loan documents and photos.",
        "NSCameraUsageDescription": "Bacou needs camera access to capture loan contract photos.",
        "NSMicrophoneUsageDescription": "Bacou needs microphone access to record video affirmations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.bacou.loan",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-dev-client",
      "expo-image-picker",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#312e81",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Bacou to use Face ID to unlock the app."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.1"
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "4f85cd30-d0c0-4db2-afde-e3072d9da88d"
      }
    },
    "owner": "sinsameak"
  }
}
